{
    "name": "stechstudio/laravel-docent",
    "description": "Docent — give your Laravel app a guide. Beautiful, contextual, permission-aware documentation that participates in your application.",
    "keywords": [
        "laravel",
        "documentation",
        "docs",
        "markdown",
        "guide",
        "help-center"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Joseph Szobody",
            "email": "joseph@stechstudio.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "league/commonmark": "^2.7",
        "phiki/phiki": "^2.2",
        "symfony/html-sanitizer": "^7.4.13 || ^8.0.13",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "prism-php/prism": "^0.100.1"
    },
    "suggest": {
        "prism-php/prism": "Required only when Docent's optional AI answers are enabled"
    },
    "autoload": {
        "psr-4": {
            "STS\\Docent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "STS\\Docent\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "STS\\Docent\\DocentServiceProvider"
            ],
            "aliases": {
                "Docent": "STS\\Docent\\Facades\\Docent"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
